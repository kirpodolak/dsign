#!/usr/bin/env bash
# Diagnostics for on-display Wi-Fi (DRM vt2 or Wayland foot+nmtui).
# If `sudo .../dsign-diagnose-wifi-on-display` fails with Permission denied (noexec /usr/local):
#   sudo bash /usr/local/bin/dsign-diagnose-wifi-on-display
set -u

echo "=== dsign-wifi-on-display diagnostics ==="
echo

echo "--- scripts ---"
for f in /usr/local/bin/dsign-wifi-on-display /usr/local/bin/dsign-show-startup-ip /usr/local/bin/dsign-nmtui-tty /usr/local/bin/dsign-nmtui-wayland; do
  if [ -e "$f" ]; then
    ls -l "$f"
    if [ ! -x "$f" ]; then
      echo "  NOTE: not executable — wifi uses: sudo bash $f"
    fi
    file "$f" || true
    head -1 "$f" | od -An -tc | head -1 || true
  else
    echo "MISSING: $f"
  fi
done
echo

echo "--- sudoers (NOPASSWD) ---"
sudo grep -H dsign-wifi /etc/sudoers.d/* 2>/dev/null || echo "(no dsign-wifi rule in /etc/sudoers.d/)"
echo

echo "--- network assistant env ---"
if [ -r /var/lib/dsign/config/network-assistant.env ]; then
  cat /var/lib/dsign/config/network-assistant.env
else
  echo "(missing /var/lib/dsign/config/network-assistant.env)"
fi
echo

echo "--- network status (boot) ---"
if [ -r /run/dsign/network-status.env ]; then
  cat /run/dsign/network-status.env
else
  echo "(missing /run/dsign/network-status.env)"
fi
echo

echo "--- mpv / display backend ---"
ps -o pid,user,tty,cmd -C mpv 2>/dev/null || echo "(mpv not running)"
mpv_count="$(pgrep -c mpv 2>/dev/null || echo 0)"
if [ "${mpv_count:-0}" -gt 1 ] 2>/dev/null; then
  echo "WARNING: ${mpv_count} mpv processes — disable DRM mpv on Wayland:"
  echo "  sudo bash /usr/local/bin/dsign-disable-drm-mpv"
  echo "  (or: sudo systemctl stop dsign-mpv.service; sudo ln -sf /dev/null /etc/systemd/system/dsign-mpv.service; sudo systemctl daemon-reload)"
fi
if [ -r /var/lib/dsign/config/wayland.env ]; then
  echo "wayland.env:"
  grep -E '^(DSIGN_DISPLAY_BACKEND|WAYLAND_DISPLAY|XDG_RUNTIME_DIR)=' /var/lib/dsign/config/wayland.env 2>/dev/null || true
  sock="${XDG_RUNTIME_DIR:-/run/user/1000}/${WAYLAND_DISPLAY:-wayland-0}"
  [ -S "$sock" ] && echo "wayland socket: OK ($sock)" || echo "wayland socket: missing ($sock)"
  command -v foot >/dev/null 2>&1 && echo "foot: OK" || echo "foot: MISSING (apt install foot)"
else
  command -v openvt >/dev/null 2>&1 && echo "openvt: OK" || echo "openvt: MISSING (apt install util-linux)"
fi
command -v nmtui-connect >/dev/null 2>&1 && echo "nmtui-connect: OK" || echo "nmtui-connect: MISSING (apt install network-manager)"
if [ -r /usr/local/bin/dsign-wifi-on-display ]; then
  echo "wayland backend (wifi script): $(grep -q is_wayland_backend /usr/local/bin/dsign-wifi-on-display 2>/dev/null && echo 'patched' || echo 'old — redeploy dsign-wifi-on-display')"
fi
if [ -f /run/dsign/playback-active ]; then
  echo "playback-active: set (manual Wi-Fi test needs: sudo rm /run/dsign/wifi-on-display-force; sudo touch /run/dsign/wifi-on-display-force; sudo bash /usr/local/bin/dsign-wifi-on-display)"
fi
echo

echo "--- sudo test as dsign (must not ask password) ---"
if id dsign >/dev/null 2>&1; then
  sudo -u dsign sudo -n /usr/local/bin/dsign-wifi-on-display 2>&1 | head -20 || true
else
  echo "(user dsign not found)"
fi
echo

echo "--- recent journal ---"
journalctl -t dsign-wifi-on-display -t dsign-show-startup-ip -t dsign-nmtui-tty -t dsign-nmtui-wayland -b --no-pager -n 30 2>/dev/null || true
