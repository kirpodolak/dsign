#!/usr/bin/env bash
# Best-effort MPV OSD for startup IP. Must NOT block mpv/digital-signage.
set -u

STARTUP_IP_FILE="${DSIGN_STARTUP_IP_FILE:-/tmp/dsign-startup-ip.txt}"
MPV_SOCKET="${DSIGN_MPV_SOCKET:-/var/lib/dsign/mpv/socket}"
SHOW_DURATION_MS="${DSIGN_STARTUP_IP_DURATION_MS:-60000}"
SOCKET_WAIT_SEC="${DSIGN_STARTUP_IP_SOCKET_WAIT_SEC:-3}"
BG_RETRY_SEC="${DSIGN_STARTUP_IP_BG_RETRY_SEC:-60}"

log() {
  logger -t dsign-show-startup-ip "$*"
}

read_ip_from_file() {
  [ -r "$STARTUP_IP_FILE" ] || return 1
  tr -d '\r\n' < "$STARTUP_IP_FILE" 2>/dev/null || true
}

primary_ip() {
  ip -4 -o addr show scope global 2>/dev/null | awk '{split($4,a,"/"); print a[1]; exit}'
}

resolve_ip() {
  local ip from_file
  from_file="$(read_ip_from_file || true)"
  if [ -n "$from_file" ]; then
        printf '%s' "$from_file"
        return 0
  fi
  allow_live="${DSIGN_STARTUP_IP_ALLOW_LIVE_LOOKUP:-1}"
  case "$allow_live" in
    1|true|yes|on|TRUE|YES|ON)
      ip="$(primary_ip || true)"
      if [ -n "$ip" ]; then
        printf '%s' "$ip"
        return 0
      fi
      ;;
  esac
  return 1
}

wait_for_socket() {
  local deadline now
  deadline=$(( $(date +%s) + SOCKET_WAIT_SEC ))
  while true; do
    if [ -S "$MPV_SOCKET" ]; then
      return 0
    fi
    now="$(date +%s)"
    if [ "$now" -ge "$deadline" ]; then
      return 1
    fi
    sleep 0.15
  done
}

send_ip_osd_once() {
  local ip_addr="$1"
  [ -n "$ip_addr" ] || return 1
  [ -S "$MPV_SOCKET" ] || return 1
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$ip_addr" "$SHOW_DURATION_MS" "$MPV_SOCKET" <<'PY' || return 1
import json, socket, sys

ip = sys.argv[1]
duration_ms = int(sys.argv[2]) if len(sys.argv) > 2 else 60000
sock_path = sys.argv[3]
payload = {
    "command": ["show-text", f"IP: {ip}", duration_ms],
    "request_id": 1,
}
try:
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(0.8)
    s.connect(sock_path)
    s.sendall((json.dumps(payload, ensure_ascii=False) + "\n").encode("utf-8"))
    s.close()
except Exception:
    sys.exit(1)
sys.exit(0)
PY
    return $?
  fi
  if command -v socat >/dev/null 2>&1; then
    printf '%s\n' "{\"command\":[\"show-text\",\"IP: ${ip_addr}\",${SHOW_DURATION_MS}]}" \
      | socat - "$MPV_SOCKET" >/dev/null 2>&1 || return 1
    return 0
  fi
  return 1
}

try_show_ip() {
  local ip_addr
  ip_addr="$(resolve_ip || true)"
  if [ -z "$ip_addr" ]; then
    log "Skip: no startup IP yet (file or live lookup)"
    return 1
  fi
  if ! wait_for_socket; then
    return 1
  fi
  if send_ip_osd_once "$ip_addr"; then
    log "OSD sent: IP=$ip_addr duration_ms=$SHOW_DURATION_MS"
    if [ -r "$STARTUP_IP_FILE" ]; then
      rm -f "$STARTUP_IP_FILE" 2>/dev/null || true
    fi
    return 0
  fi
  return 1
}

background_retry() {
  local ip_addr deadline
  deadline=$(( $(date +%s) + BG_RETRY_SEC ))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    ip_addr="$(resolve_ip || true)"
    if [ -n "$ip_addr" ] && send_ip_osd_once "$ip_addr"; then
      log "OSD sent (background): IP=$ip_addr"
      if [ -r "$STARTUP_IP_FILE" ]; then
        rm -f "$STARTUP_IP_FILE" 2>/dev/null || true
      fi
      return 0
    fi
    sleep 0.5
  done
  log "Background retry ended without OSD"
  return 0
}

if try_show_ip; then
  exit 0
fi

if [ "${DSIGN_STARTUP_IP_BACKGROUND_RETRY:-1}" != "0" ]; then
  ( background_retry ) >/dev/null 2>&1 &
  disown 2>/dev/null || true
  log "Spawned background IP OSD retry (${BG_RETRY_SEC}s)"
fi
exit 0
