#!/bin/bash
# Snapshot mpv log when dsign-mpv stops so the next start does not truncate evidence.
# Run as: /bin/bash /usr/local/bin/dsign-mpv-archive-log (systemd ExecStopPost; do not rely on +x).

set -u

_resolve_log() {
	if [[ -n "${DSIGN_MPV_LOG_FILE:-}" ]] && [[ -f "${DSIGN_MPV_LOG_FILE}" ]]; then
		printf '%s\n' "${DSIGN_MPV_LOG_FILE}"
		return 0
	fi
	local f
	for f in /var/lib/dsign/mpv/mpv.log /var/log/dsign/mpv.log; do
		if [[ -f "$f" ]]; then
			printf '%s\n' "$f"
			return 0
		fi
	done
	return 1
}

LOG="$(_resolve_log || true)"
if [[ -z "${LOG}" ]] || [[ ! -s "${LOG}" ]]; then
	exit 0
fi

# Always store snapshots under /var/lib (writable by dsign in our units), even when
# --log-file points at /var/log/dsign/mpv.log (Pi install).
ARCHIVE="${DSIGN_MPV_LOG_ARCHIVE_DIR:-/var/lib/dsign/mpv/archive}"
KEEP="${DSIGN_MPV_LOG_ARCHIVE_KEEP:-25}"

umask 022
mkdir -p "$ARCHIVE" || exit 0

stamp="$(date -u +%Y%m%dT%H%M%SZ)_$$"
dest="$ARCHIVE/mpv-before-stop-${stamp}.log"
if ! cp -a -- "$LOG" "$dest" 2>/dev/null; then
	exit 0
fi

ln -sfn "$(basename "$dest")" "$ARCHIVE/mpv-last-stop.log" 2>/dev/null || true

mapfile -t _files < <(ls -t "$ARCHIVE"/mpv-before-stop-*.log 2>/dev/null || true)
if ((${#_files[@]} > KEEP)); then
	for ((i = KEEP; i < ${#_files[@]}; i++)); do
		rm -f -- "${_files[$i]}" 2>/dev/null || true
	done
fi

exit 0
