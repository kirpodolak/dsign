#!/bin/bash
# Snapshot mpv.log when dsign-mpv stops/restarts so diagnostics keep the run that ended.
# Invoked from systemd ExecStopPost=- (failure must not block shutdown).

set -u

LOG="/var/lib/dsign/mpv/mpv.log"
ARCHIVE="/var/lib/dsign/mpv/archive"
KEEP="${DSIGN_MPV_LOG_ARCHIVE_KEEP:-25}"

umask 022
mkdir -p "$ARCHIVE" || exit 0

if [[ ! -f "$LOG" ]] || [[ ! -s "$LOG" ]]; then
	exit 0
fi

stamp="$(date -u +%Y%m%dT%H%M%SZ)_$$"
dest="$ARCHIVE/mpv-before-stop-${stamp}.log"
if ! cp -a -- "$LOG" "$dest" 2>/dev/null; then
	exit 0
fi

ln -sfn "$(basename "$dest")" "$ARCHIVE/mpv-last-stop.log" 2>/dev/null || true

# Drop oldest archives beyond KEEP (newest first).
mapfile -t _files < <(ls -t "$ARCHIVE"/mpv-before-stop-*.log 2>/dev/null || true)
if ((${#_files[@]} > KEEP)); then
	for ((i = KEEP; i < ${#_files[@]}; i++)); do
		rm -f -- "${_files[$i]}" 2>/dev/null || true
	done
fi

exit 0
