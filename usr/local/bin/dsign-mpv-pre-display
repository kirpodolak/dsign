#!/usr/bin/env bash
# Run as root from dsign-mpv.service ExecStartPre (PermissionsStartOnly=yes).
# Invoked via /bin/bash (not exec) so noexec on /usr/local does not break startup.
# Switch to tty1 once per boot for DRM; avoid repeated chvt on mpv restart.
set -u

MARKER_DIR="/run/dsign"
MARKER="${MARKER_DIR}/mpv-display-ready"
BOOT_ID=""
if [ -r /proc/sys/kernel/random/boot_id ]; then
  BOOT_ID="$(tr -d '\n-' < /proc/sys/kernel/random/boot_id)"
fi

mkdir -p "$MARKER_DIR" 2>/dev/null || {
  echo "dsign-mpv-pre-display: cannot mkdir $MARKER_DIR" >&2
  exit 0
}
chown dsign:dsign "$MARKER_DIR" 2>/dev/null || true
chmod 0775 "$MARKER_DIR" 2>/dev/null || true

if [ -n "$BOOT_ID" ] && [ -f "$MARKER" ]; then
  saved="$(tr -d '\n' < "$MARKER" 2>/dev/null || true)"
  if [ "$saved" = "$BOOT_ID" ]; then
    exit 0
  fi
fi

if ! /bin/chvt 1 2>/dev/null; then
  echo "dsign-mpv-pre-display: chvt 1 failed" >&2
fi

if [ -n "$BOOT_ID" ]; then
  printf '%s' "$BOOT_ID" >"$MARKER" 2>/dev/null || {
    echo "dsign-mpv-pre-display: cannot write $MARKER" >&2
    exit 0
  }
else
  touch "$MARKER" 2>/dev/null || true
fi
exit 0
