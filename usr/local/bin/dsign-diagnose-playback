#!/usr/bin/env bash
# Playback / MPV / playlist diagnostics for dsign signage devices (DRM + Wayland).
set -u

SOCK="${DSIGN_MPV_SOCKET:-/var/lib/dsign/mpv/socket}"
LOG="${DSIGN_MPV_LOG_FILE:-/var/lib/dsign/mpv/mpv.log}"
ARCHIVE="${DSIGN_MPV_ARCHIVE:-/var/lib/dsign/mpv/archive}"
DB="${DSIGN_DB_PATH:-/var/lib/dsign/database.db}"
REPO="${DSIGN_REPO:-/home/dsign/dsign}"
JOURNAL_LINES="${DSIGN_DIAG_JOURNAL_LINES:-600}"
SINCE="${DSIGN_DIAG_SINCE:-}"
CACHE_DIR="${DSIGN_CONTENT_CACHE_DIR:-/var/lib/dsign/media/cache}"
WAYLAND_PROFILE="${DSIGN_MPV_WAYLAND_PROFILE:-/var/lib/dsign/mpv-minimal/profiles/intel-iris-xe-balanced-wayland.conf}"

_diag_env_default() {
  local name="$1"
  local default="$2"
  if [ -n "${!name:-}" ]; then
    printf '  %s=%s (env)\n' "$name" "${!name}"
  else
    printf '  %s=%s (default)\n' "$name" "$default"
  fi
}

_diag_running_env() {
  local prefix="$1"
  local pid
  pid="$(pgrep -f 'python.*(/run\.py|digital.signage)' 2>/dev/null | head -1 || true)"
  if [ -z "$pid" ] && pgrep -f 'venv/bin/python' >/dev/null 2>&1; then
    pid="$(pgrep -f 'venv/bin/python.*run\.py' 2>/dev/null | head -1 || true)"
  fi
  if [ -n "$pid" ] && [ -r "/proc/$pid/environ" ]; then
    tr '\0' '\n' <"/proc/$pid/environ" 2>/dev/null | grep -E "^${prefix}" | sed 's/^/  runtime: /' || true
  fi
}

_diag_human_bytes() {
  local n="${1:-0}"
  if command -v numfmt >/dev/null 2>&1; then
    numfmt --to=iec-i --suffix=B "$n" 2>/dev/null || echo "${n}B"
  else
    echo "${n} bytes"
  fi
}

_diag_probe_internet() {
  local host="$1"
  local port="${2:-443}"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$host" "$port" <<'PY'
import socket, sys
h, p = sys.argv[1], int(sys.argv[2])
try:
    socket.create_connection((h, p), timeout=2.0).close()
    print("OK")
except OSError as e:
    print(f"FAIL ({e})")
PY
  else
    echo "SKIP (no python3)"
  fi
}

echo "=== dsign playback diagnostics ==="
echo "host: $(hostname)  time: $(date -Is 2>/dev/null || date)"
echo

echo "--- display backend ---"
if [ -r /var/lib/dsign/config/wayland.env ]; then
  grep -E '^(DSIGN_DISPLAY_BACKEND|WAYLAND_DISPLAY|XDG_RUNTIME_DIR)=' \
    /var/lib/dsign/config/wayland.env 2>/dev/null || true
fi
if [ -S "${XDG_RUNTIME_DIR:-/run/user/1000}/${WAYLAND_DISPLAY:-wayland-0}" ] \
  || [ -S /run/user/1000/wayland-0 ]; then
  echo "wayland socket: OK"
else
  echo "wayland socket: MISSING"
fi
echo

echo "--- services ---"
for u in digital-signage.service dsign-mpv-wayland.service dsign-compositor.service dsign-logo.service dsign-mpv.service; do
  st="$(systemctl is-active "$u" 2>/dev/null || echo unknown)"
  en="$(systemctl is-enabled "$u" 2>/dev/null || echo unknown)"
  printf '  %-28s active=%-10s enabled=%s\n' "$u" "$st" "$en"
done
if systemctl is-enabled dsign-mpv.service 2>/dev/null | grep -qv masked; then
  echo "  WARNING: dsign-mpv.service (DRM) is not masked — dual mpv can stall playback:"
  echo "    sudo bash /usr/local/bin/dsign-disable-drm-mpv"
fi
echo

echo "--- mpv processes ---"
mpv_n="$(pgrep -c mpv 2>/dev/null || echo 0)"
echo "mpv count: ${mpv_n:-0}"
ps -o pid,tty,etime,cmd -C mpv 2>/dev/null | sed 's/^/  /' || echo "  (mpv not running)"
if [ "${mpv_n:-0}" -gt 1 ] 2>/dev/null; then
  echo "  WARNING: multiple mpv — only dsign-mpv-wayland should run on Wayland"
fi
if ps -o cmd -C mpv 2>/dev/null | grep -q -- '--vo=drm'; then
  echo "  WARNING: DRM mpv detected (--vo=drm) — causes idle logo on Wayland"
fi
echo

echo "--- IPC socket ---"
if [ -S "$SOCK" ]; then
  ls -la "$SOCK"
  if command -v lsof >/dev/null 2>&1; then
    lsof "$SOCK" 2>/dev/null | sed 's/^/  /' || true
  fi
else
  echo "(socket missing: $SOCK)"
fi
echo

mpv_prop() {
  local prop="$1"
  if ! command -v python3 >/dev/null 2>&1 || [ ! -S "$SOCK" ]; then
    return 1
  fi
  python3 <<PY
import json, socket
s = "${SOCK}"
prop = "${prop}"
try:
    c = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    c.settimeout(2)
    c.connect(s)
    c.sendall((json.dumps({"command":["get_property",prop],"request_id":1})+"\\n").encode())
    d = json.loads(c.recv(4096).decode().split("\\n",1)[0])
    print(d.get("data",""))
except Exception as e:
    print("?", e)
PY
}

echo "--- mpv live snapshot (idle-active=True => logo on screen) ---"
if [ -S "$SOCK" ]; then
  for p in idle-active pause path stream-open-filename time-pos duration demuxer-cache-time eof-reached; do
    v="$(mpv_prop "$p" 2>/dev/null || echo '?')"
    printf '  %-22s %s\n' "$p:" "$v"
  done
  vs="$(mpv_prop "video-sync" 2>/dev/null || true)"
  if [ -n "$vs" ] && [ "$vs" != "?" ]; then
    printf '  %-22s %s\n' "video-sync (live):" "$vs"
  fi
  # Heuristic: local content cache vs network stream
  pth="$(mpv_prop path 2>/dev/null || true)"
  if [[ "$pth" == *"/media/cache/"* ]]; then
    echo "  playback_source:       content_cache (local mp4)"
  elif [[ "$pth" == ytdl://* ]] || [[ "$pth" == http://* ]] || [[ "$pth" == https://* ]]; then
    echo "  playback_source:       network (ytdl/http)"
  elif [ -n "$pth" ] && [ "$pth" != "?" ]; then
    echo "  playback_source:       local file"
  fi
else
  echo "(no IPC)"
fi
echo

echo "--- mpv Wayland profile (A4 video-sync) ---"
if [ -r "$WAYLAND_PROFILE" ]; then
  grep -E '^(video-sync|interpolation)=' "$WAYLAND_PROFILE" 2>/dev/null | sed 's/^/  /' || true
  if ! grep -q '^video-sync=' "$WAYLAND_PROFILE" 2>/dev/null; then
    echo "  (video-sync not set in profile)"
  fi
else
  echo "  (missing $WAYLAND_PROFILE)"
fi
echo

echo "--- content cache (C1) ---"
_ccode=""
for _cp in "$REPO/dsign/services/content_cache.py" "$REPO/services/content_cache.py"; do
  if [ -f "$_cp" ]; then
    _ccode="$_cp"
    break
  fi
done
if [ -n "$_ccode" ]; then
  echo "  code: content_cache.py present ($_ccode)"
else
  echo "  code: content_cache.py not in $REPO (runtime may still use installed copy)"
fi
_diag_env_default DSIGN_CONTENT_CACHE_ENABLED "1"
_diag_env_default DSIGN_CONTENT_CACHE_PREFETCH "1"
_diag_env_default DSIGN_CONTENT_CACHE_PLAY_WHEN_READY "1"
_diag_env_default DSIGN_CONTENT_CACHE_MAX_GB "8"
_diag_env_default DSIGN_CONTENT_CACHE_DIR "$CACHE_DIR"
_diag_running_env 'DSIGN_CONTENT_CACHE_'
if journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep -q 'ContentCache wired'; then
  echo "  service: ContentCache wired (journal this boot)"
else
  echo "  service: ContentCache wired — not seen in journal this boot"
fi
if [ -d "$CACHE_DIR" ]; then
  ready_n=0
  partial_n=0
  legacy_n=0
  total_b=0
  echo "  cache_dir: $CACHE_DIR"
  shopt -s nullglob
  for f in "$CACHE_DIR"/ext-*.mp4; do
    [ -f "$f" ] || continue
    sz=$(stat -c%s "$f" 2>/dev/null || echo 0)
    total_b=$((total_b + sz))
    ok="maybe"
    if command -v ffprobe >/dev/null 2>&1; then
      if ffprobe -v error -select_streams v:0 -show_entries stream=codec_type -of csv=p=0 "$f" 2>/dev/null \
        | grep -qi video; then
        ok="ready"
        ready_n=$((ready_n + 1))
      else
        ok="invalid"
      fi
    else
      ready_n=$((ready_n + 1))
    fi
    printf '    ready  %-12s %8s  %s\n' "$(basename "$f")" "$(_diag_human_bytes "$sz")" "$ok"
  done
  for f in "$CACHE_DIR"/*.part "$CACHE_DIR"/*/*.part "$CACHE_DIR"/*-*-Frag*.part; do
    [ -e "$f" ] || continue
    partial_n=$((partial_n + 1))
    sz=$(stat -c%s "$f" 2>/dev/null || echo 0)
    printf '    partial %-40s %s\n' "$(basename "$f")" "$(_diag_human_bytes "$sz")"
  done
  for f in "$CACHE_DIR"/*mp4.mp4*; do
    [ -e "$f" ] || continue
    legacy_n=$((legacy_n + 1))
  done
  shopt -u nullglob
  echo "  summary: ready=$ready_n partial_files=$partial_n total_ready=$(_diag_human_bytes "$total_b")"
  if [ "$legacy_n" -gt 0 ]; then
    echo "  WARNING: legacy ext-N.mp4.mp4.* files ($legacy_n) — yt-dlp template bug; git pull + rm partials + restart digital-signage"
  fi
  if [ "$partial_n" -gt 0 ] && [ "$ready_n" -eq 0 ]; then
    echo "  note: prefetch in progress (long Rutube videos may take 30+ min)"
  fi
else
  echo "  cache_dir: MISSING ($CACHE_DIR)"
fi
echo "  yt-dlp: $(command -v yt-dlp 2>/dev/null || echo missing) $(yt-dlp --version 2>/dev/null | head -1 || true)"
echo

echo "--- network reachability ---"
gw="$(ip route 2>/dev/null | awk '/^default /{print $3; exit}')"
if [ -n "$gw" ]; then
  if ping -c 1 -W 2 "$gw" >/dev/null 2>&1; then
    echo "  gateway $gw: OK"
  else
    echo "  gateway $gw: FAIL (no ping)"
  fi
else
  echo "  gateway: (no default route)"
fi
inet="$(_diag_probe_internet 1.1.1.1 53)"
echo "  internet (1.1.1.1:53): $inet"
rut="$(_diag_probe_internet rutube.ru 443)"
echo "  rutube.ru:443: $rut"
if command -v curl >/dev/null 2>&1; then
  code="$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 5 https://rutube.ru/ 2>/dev/null || echo timeout)"
  echo "  curl rutube.ru: $code"
fi
echo

echo "--- markers ---"
ls -la /run/dsign/playback-active /run/dsign/startup-ip-shown 2>/dev/null | sed 's/^/  /' \
  || echo "  (no markers under /run/dsign/)"
echo

echo "--- playback DB ---"
if command -v sqlite3 >/dev/null 2>&1 && [ -r "$DB" ]; then
  sqlite3 -header -column "$DB" \
    "SELECT id, playlist_id, status, datetime('now','localtime') AS now_local FROM playback_status LIMIT 1;" 2>/dev/null || true
else
  echo "(sqlite3 or $DB unavailable)"
fi
echo

echo "--- timeline (journal, last events) ---"
JARGS=(journalctl -u digital-signage.service --no-pager -n "$JOURNAL_LINES")
if [ -n "$SINCE" ]; then
  JARGS+=(--since "$SINCE")
else
  JARGS+=(-b)
fi
"${JARGS[@]}" 2>/dev/null | grep -E \
  'Playlist item (starting|finished)|proactive_refresh|Proactive refresh|mid-stream network reload|Network stream ready|ytdl stream did not open|ytdl: retrying|MPV network stream debug|Slideshow loop paused|Resumed playlist|MPV IPC socket recreated|hung|forcing systemd restart|deferred_unpause|instant_eof|vo init|loadfile|Content cache' \
  | tail -n 60 || echo "(no matching journal lines)"
echo

echo "--- content cache (journal, this boot) ---"
journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep -iE 'Content cache|ContentCache wired' \
  | tail -15 | sed 's/^/  /' || echo "  (no Content cache lines this boot)"
echo

echo "--- network health (journal hints) ---"
journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep -E 'consecutive_ytdl_failures|Aborting playlist scan after consecutive|cdn_may_be_down' \
  | tail -5 | sed 's/^/  /' || echo "  (no ytdl streak warnings this boot)"
ytdl_fail_n="$(journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep -c 'ytdl stream did not open' || echo 0)"
echo "  ytdl open failures (boot): $ytdl_fail_n"
echo

echo "--- recovery / hung (journal) ---"
journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep -iE 'hung|IPC socket recreated|stall recovery|forcing systemd restart|ytdl stream did not open' \
  | tail -20 || true
echo

echo "--- dsign-mpv-wayland (journal) ---"
journalctl -u dsign-mpv-wayland.service -b --no-pager -n 25 2>/dev/null || true
echo

echo "--- dsign-mpv DRM unit (journal, should be empty if masked) ---"
journalctl -u dsign-mpv.service -b --no-pager -n 15 2>/dev/null || true
echo

echo "--- mpv.log errors (vo/drm, alsa busy, open fail) ---"
if [ -r "$LOG" ]; then
  grep -iE 'vo/drm|Error opening/initializing|alsa.*busy|failed to commit atomic|ytdl stream did not|EOF' "$LOG" 2>/dev/null \
    | tail -15 || echo "  (no error patterns in current log tail — check archive)"
  echo "  ... last HLS/opens:"
  tail -n 30 "$LOG" | grep -E 'Opening|segment-|hls' | tail -8 || tail -3 "$LOG" | sed 's/^/  /'
else
  echo "(missing $LOG)"
fi
echo

echo "--- mpv archive (recent stops) ---"
if [ -d "$ARCHIVE" ]; then
  ls -lt "$ARCHIVE" 2>/dev/null | head -5 | sed 's/^/  /'
  latest="$(ls -t "$ARCHIVE"/mpv-before-stop-*.log 2>/dev/null | head -1 || true)"
  if [ -n "$latest" ] && [ -r "$latest" ]; then
    echo "  errors in latest archive $(basename "$latest"):"
    grep -iE 'vo/drm|Error opening|alsa.*busy|failed to commit|EOF reached' "$latest" 2>/dev/null \
      | tail -8 | sed 's/^/    /' || echo "    (no vo/drm/alsa errors)"
  fi
else
  echo "(no archive dir)"
fi
echo

echo "--- finished reasons (this boot) ---"
journalctl -u digital-signage.service -b --no-pager 2>/dev/null \
  | grep 'Playlist item finished' \
  | sed 's/.*"reason": "//;s/".*//' \
  | sort | uniq -c | sort -rn | head -10 || true
echo

echo "=== hints ==="
echo "  Immediate snapshot:     bash $0"
echo "  Last 2 hours only:      SINCE='2 hours ago' bash $0"
echo "  Idle logo + idle-active=True: mpv not playing (check vo/drm dual mpv above)"
echo "  Fix dual mpv on Wayland: sudo bash /usr/local/bin/dsign-disable-drm-mpv"
echo "  Content cache API:      cache_state in GET /api/playback/status or GET /api/health (needs login)"
echo "  Cache partial stuck:    ls -lh $CACHE_DIR; journalctl -u digital-signage | grep 'Content cache'"
echo "  Save full bundle:       SINCE='12 hours ago' DSIGN_DIAG_JOURNAL_LINES=3000 bash $0 | tee /tmp/dsign-playback-$(date +%Y%m%dT%H%M).txt"
