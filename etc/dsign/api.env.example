# Optional API token for monitoring scripts (B4 partial: /api/health).
# Copy to /etc/dsign/api.env, set a strong token, restrict permissions:
#   sudo install -m 600 -o dsign -g dsign api.env.example /etc/dsign/api.env
#   sudo systemctl restart digital-signage.service
#
# curl -s -H "Authorization: Bearer YOUR_TOKEN" http://127.0.0.1:5000/api/health | jq .
#
# DSIGN_API_TOKEN=
