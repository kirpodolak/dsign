# API token for monitoring: GET /api/health with Authorization: Bearer <token>
# Managed by: sudo dsign-api-token install | rotate | show | status
# File on player: /etc/dsign/api.env (not in git)
#
# curl -s -H "Authorization: Bearer YOUR_TOKEN" http://127.0.0.1:5000/api/health | jq .
#
# DSIGN_API_TOKEN=
