# OTA self-update settings (backlog D1). Copy to /etc/dsign/ota.env on player.
# Managed manually or via fleet config push (future).
#
# See docs/D1_OTA.md

# DSIGN_OTA_ENABLED=1
# DSIGN_OTA_BRANCH=main
# DSIGN_OTA_REMOTE=origin
# DSIGN_PROJECT_ROOT=/home/dsign/dsign   # must contain .git/ for check/download
# DSIGN_VENV=/home/dsign/venv
# DSIGN_DISPLAY_BACKEND=drm
