# OTA self-update settings (backlog D1). Copy to /etc/dsign/ota.env on player.
# Managed manually or via fleet config push (future).
#
# See docs/D1_OTA.md

# DSIGN_OTA_ENABLED=1
# DSIGN_OTA_BRANCH=main
# DSIGN_OTA_REMOTE=origin

# Git clone (fetch/merge). On Pi running signage from the same tree:
# DSIGN_PROJECT_ROOT=/home/dsign/dsign-new
# (omit DSIGN_RUNTIME_ROOT — defaults to project_root / same-tree)

# Two-tree layout only when systemd runs /home/dsign/dsign but git is in dsign-new:
# DSIGN_RUNTIME_ROOT=/home/dsign/dsign

# DSIGN_OTA_SMOKE_CHECK=1
# DSIGN_OTA_AUTO_ROLLBACK=1
# DSIGN_OTA_RESTART_WAIT_SEC=90

# DSIGN_VENV=/home/dsign/venv
# DSIGN_DISPLAY_BACKEND=wayland
