# Template for /var/lib/dsign/config/wayland.env
# install_dsign.sh copies this file and appends WLR_DRM_DEVICES on first install.
# Edit the deployed file on each device (Intel x86 often needs card1, not card0).
#
# Loaded by: dsign-compositor.service, dsign-mpv-wayland.service, screenshot/wifi helpers
# (systemd Environment= lines in those units override duplicate keys below.)

DSIGN_DISPLAY_BACKEND=wayland

# Wayland socket name (labwc on this device uses wayland-0)
WAYLAND_DISPLAY=wayland-0

# Runtime dir for user dsign (uid 1000)
XDG_RUNTIME_DIR=/run/user/1000

# *** Device-specific: which DRM node labwc uses for KMS output ***
# install_dsign.sh auto-picks the first /dev/dri/card* if this file is created by installer.
# On Intel signage PCs the display GPU is often card1:
WLR_DRM_DEVICES=/dev/dri/card0

# wlroots / labwc (compositor unit does NOT override WLR_RENDERER — set here)
WLR_BACKENDS=drm
# Intel x86 DP: gles2 often crashes labwc (swapchain failed test); pixman is stable.
WLR_RENDERER=pixman
LIBSEAT_BACKEND=seatd
